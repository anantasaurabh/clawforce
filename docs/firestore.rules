rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check if the user is the Superadmin (by Email or Role)
    function isAdmin() {
      let userDoc = get(/databases/$(database)/documents/artifacts/clwhq-001/public/data/users/$(request.auth.uid));
      return isAuthenticated() && 
             (request.auth.token.email == "admin@clawforce.hq" || userDoc.data.role == 'admin');
    }

    // --- APPLICATION DATA (clwhq-001) ---
    match /artifacts/clwhq-001/{allPaths=**} {
      
      // 1. Any logged-in personnel can READ everything
      allow read: if isAuthenticated();

      // 2. Only Admins can WRITE to shared data
      allow write: if isAdmin();
    }

    // --- USER PRIVATE DATA ---
    
    // 3. Users can always write to their own private folders
    match /artifacts/clwhq-001/userConfigs/{userId} {
      allow write: if isAuthenticated() && request.auth.uid == userId;
      match /{allPaths=**} {
        allow write: if isAuthenticated() && request.auth.uid == userId;
      }
    }
    
    match /artifacts/clwhq-001/userAuthorizations/{userId} {
      allow write: if isAuthenticated() && request.auth.uid == userId;
      match /{allPaths=**} {
        allow write: if isAuthenticated() && request.auth.uid == userId;
      }
    }
    
    match /artifacts/clwhq-001/public/data/users/{userId} {
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // 4. Operators can manage their own tasks/posts/missions
    match /artifacts/clwhq-001/public/data/{type}/{docId} {
      allow write: if (type == 'tasks' || type == 'pending_posts' || type == 'missions' || type == 'silent_tasks') && 
        isAuthenticated() && 
        (isAdmin() || request.resource.data.ownerId == request.auth.uid || resource.data.ownerId == request.auth.uid);
    }
  }
}
